# .gitattributes — MyPresensi PBL TRPL
# Normalisasi line ending lintas OS (Windows CRLF ↔ Unix LF)
# Tanpa file ini, diff bisa noisy karena editor di Windows simpan CRLF.

# ============================================================
# DEFAULT — auto detect text, normalize ke LF saat commit
# ============================================================
* text=auto eol=lf

# ============================================================
# TEXT — explicit LF (cross-platform clean)
# ============================================================
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.dart      text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.gradle    text eol=lf
*.kt        text eol=lf
*.swift     text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.env.example text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# PowerShell scripts harus CRLF (Windows-native)
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# ============================================================
# BINARY — jangan diff, jangan modify line ending
# ============================================================
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.bmp       binary
*.tiff      binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.7z        binary
*.rar       binary
*.tflite    binary
*.pb        binary
*.jks       binary
*.keystore  binary
*.p12       binary
*.pfx       binary
*.mp4       binary
*.mov       binary
*.mp3       binary
*.wav       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary

# ============================================================
# GENERATED — collapse di GitHub diff view & exclude dari language stats
# ============================================================
package-lock.json   linguist-generated=true -diff
yarn.lock           linguist-generated=true -diff
pnpm-lock.yaml      linguist-generated=true -diff
pubspec.lock        linguist-generated=true -diff
*.g.dart            linguist-generated=true
*.freezed.dart      linguist-generated=true

# ============================================================
# DOCUMENTATION — tetap masuk language stats
# ============================================================
docs/**             linguist-documentation=true
*.md                linguist-documentation=false
