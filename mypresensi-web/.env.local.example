# ============================================================
# Supabase — Dashboard > Settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# RAHASIA — bypass RLS. JANGAN pernah commit / expose ke client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# Firebase Admin SDK — WAJIB untuk push notification (FCM)
# Firebase Console > Project Settings > Service accounts >
# Generate new private key. Paste SELURUH isi file JSON sebagai
# SATU BARIS (single-line). Panduan: docs/setup/firebase-setup.md
# Tanpa ini, pengiriman notifikasi sesi/izin akan gagal.
# ============================================================
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ============================================================
# Google Gemini API — untuk fitur AI Chat (dashboard web + mobile)
# Buat key gratis di https://aistudio.google.com/apikey
# Tanpa key ini endpoint AI chat balas 503; fitur lain tetap jalan.
# ============================================================
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key
