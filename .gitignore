# Root .gitignore — MyPresensi PBL TRPL
# Lindungi file sensitif (kredensial, secrets) supaya tidak ter-commit ke Git.

# =========================================================
# KREDENSIAL & SECRETS — JANGAN PERNAH COMMIT
# =========================================================
credentials-MUSTREAD.txt
.dev-accounts.md
update-mcp-token.ps1
*.bak

# Environment files (sub-repos sudah punya .gitignore sendiri,
# tapi defensive di root juga)
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Tokens & keys
**/access-token*
**/secret*
**/*.key
**/*.pem
**/*.p12

# Firebase secrets (FCM) — JANGAN PERNAH COMMIT
# Service Account JSON = setara service_role key. Kalau bocor, rotate via Firebase Console.
**/*firebase-adminsdk*.json
**/google-services.json
**/GoogleService-Info.plist

# =========================================================
# IDE & EDITOR
# =========================================================
.vscode/
.idea/
*.iml
.windsurf/runs/

# =========================================================
# OS-SPECIFIC
# =========================================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# PYTHON VIRTUAL ENV (kalau ada untuk script utility)
# =========================================================
.venv/
__pycache__/
*.pyc

# =========================================================
# TEMP / LOG
# =========================================================
*.log
tmp/
temp/
*.tmp

# =========================================================
# OLD PROJECT — Semester 5 (jangan ikut push, 230+ MB)
# =========================================================
Projek Pbl-Semester-5/

# =========================================================
# BUG RECORDINGS (video besar, simpan lokal saja)
# =========================================================
*.mp4
*.mov
masalah-*.mp4
masalah-*.jpeg

# =========================================================
# BUILD CACHE (Flutter & Gradle besar, jangan push)
# =========================================================
**/.gradle/
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies

# =========================================================
# REFERENSI & MOCKUPS (JANGAN COMMIT)
# =========================================================
Refrensi/
docs/mockups/
docs/ui-research/mockups/
/*.pdf
docs/*.html
gambar/Prodi/colors*
gambar/Prodi/get_colors.py

# =========================================================
# MATERI PRESENTASI & DRAF SCRUM (JANGAN COMMIT)
# =========================================================
PRESENTATION_SCRIPT.md
docs/Prompt_PPT_Scrum.md
docs/Scrum_MyPresensi_*
/workflow_mypresensi.md

# =========================================================
# SKRIP UTILITAS LOKAL (JANGAN COMMIT)
# =========================================================
/*.ps1
/git_files.txt
/implementation_plan-reset-password.md
scripts/generate_mockup_pdf*.py
mypresensi-web/check_fcm_logs.js
mypresensi-web/fetch_logs.js
mypresensi-web/test_db.js

# =========================================================
# JANGAN COMMIT — info MCP/dev tooling & AI Agent
# =========================================================
.windsurf/
.kiro/
.agents/
supabase/.temp/
